{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "dev": true,
      "qa": true,
      "prod": true
    }
  },
  "ignoreCommand": "bash -c '[[ \"$VERCEL_GIT_COMMIT_REF\" != \"dev\" && \"$VERCEL_GIT_COMMIT_REF\" != \"qa\" && \"$VERCEL_GIT_COMMIT_REF\" != \"prod\" ]]'",
  "framework": "vite",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @testimonials/icons build && cd apps/web && npx vite build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
