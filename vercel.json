{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "git": {
    "deploymentEnabled": {
      "dev": true,
      "main": true
    }
  },
  "framework": "vite",
  "installCommand": "pnpm install",
  "buildCommand": "pnpm --filter @testimonials/icons build && cd apps/web && npx vite build",
  "outputDirectory": "apps/web/dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
